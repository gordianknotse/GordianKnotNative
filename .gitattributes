# Normalize line endings: LF in the repo, native in the working tree.
* text=auto

# Keep these as LF regardless of platform.
*.cpp   text eol=lf
*.h     text eol=lf
*.cmake text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf

# Binary artifacts (never normalize).
*.dll binary
*.pdb binary
*.lib binary
*.esp binary
*.esm binary
*.bsa binary
*.pex binary
